type http_request_result = 
 record {
   body: blob;
   headers: vec http_header;
   status: nat;
 };
type http_header = 
 record {
   name: text;
   value: text;
 };
type _ImmutableObjectStorageRefillResult = 
 record {
   success: opt bool;
   topped_up_amount: opt nat;
 };
type _ImmutableObjectStorageRefillInformation = record {
                                                  proposed_top_up_amount:
                                                   opt nat;};
type _ImmutableObjectStorageCreateCertificateResult = 
 record {
   blob_hash: text;
   method: text;
 };
type UserRole = 
 variant {
   admin;
   guest;
   user;
 };
type UserProfile = record {name: text;};
type UserInfo = 
 record {
   addressLine1: text;
   addressLine2: text;
   city: text;
   country: text;
   email: text;
   name: text;
   phone: text;
 };
type TransformationOutput = 
 record {
   body: blob;
   headers: vec http_header;
   status: nat;
 };
type TransformationInput = 
 record {
   context: blob;
   response: http_request_result;
 };
type StripeSessionStatus = 
 variant {
   completed: record {
                response: text;
                userPrincipal: opt text;
              };
   failed: record {error: text;};
 };
type StripeConfiguration = 
 record {
   allowedCountries: vec text;
   secretKey: text;
 };
type ShoppingItem = 
 record {
   currency: text;
   priceInCents: nat;
   productDescription: text;
   productName: text;
   quantity: nat;
 };
type ProfileResult = 
 variant {
   err: text;
   ok: UserInfo;
 };
type Product = 
 record {
   finish: PrintFinish;
   price: nat;
   printId: PrintId;
   printSize: PrintSize;
   productLabel: text;
 };
type PrintUpdate = 
 record {
   active: bool;
   description: text;
   image: ExternalBlob;
   title: text;
 };
type PrintSize = 
 record {
   height: nat;
   width: nat;
 };
type PrintId = nat;
type PrintFinish = 
 variant {
   glossy;
   matte;
   satin;
 };
type Print = 
 record {
   active: bool;
   description: text;
   id: PrintId;
   image: ExternalBlob;
   title: text;
 };
type ExternalBlob = blob;
type AuthResult = 
 variant {
   err: text;
   ok: text;
 };
service : {
  _immutableObjectStorageBlobsAreLive: (hashes: vec blob) -> (vec bool) query;
  _immutableObjectStorageBlobsToDelete: () -> (vec blob) query;
  _immutableObjectStorageConfirmBlobDeletion: (blobs: vec blob) -> ();
  _immutableObjectStorageCreateCertificate: (blobHash: text) ->
   (_ImmutableObjectStorageCreateCertificateResult);
  _immutableObjectStorageRefillCashier: (refillInformation:
   opt _ImmutableObjectStorageRefillInformation) ->
   (_ImmutableObjectStorageRefillResult);
  _immutableObjectStorageUpdateGatewayPrincipals: () -> ();
  _initializeAccessControl: () -> ();
  addProduct: (product: Product) -> ();
  assignCallerUserRole: (user: principal, role: UserRole) -> ();
  createCheckoutSession: (items: vec ShoppingItem, successUrl: text,
   cancelUrl: text) -> (text);
  createPrint: (newPrint: PrintUpdate) -> (PrintId);
  deleteMyAccount: (token: text) -> (AuthResult);
  deletePrint: (printId: PrintId) -> ();
  deleteProduct: (productId: text) -> ();
  getActivePrints: () -> (vec Print) query;
  getAllPrints: () -> (vec Print) query;
  getAllProducts: () -> (vec Product) query;
  getCallerUserProfile: () -> (opt UserProfile) query;
  getCallerUserRole: () -> (UserRole) query;
  getMyProfile: (token: text) -> (ProfileResult);
  getPrint: (printId: PrintId) -> (Print) query;
  getProduct: (productId: text) -> (Product) query;
  getStripeSessionStatus: (sessionId: text) -> (StripeSessionStatus);
  getUserProfile: (user: principal) -> (opt UserProfile) query;
  isCallerAdmin: () -> (bool) query;
  isStripeConfigured: () -> (bool) query;
  saveCallerUserProfile: (profile: UserProfile) -> ();
  saveMyName: (token: text, name: text) -> (AuthResult);
  saveMyProfile: (token: text, name: text, phone: text, addressLine1: 
   text, addressLine2: text, city: text, country: text) -> (AuthResult);
  setStripeConfiguration: (config: StripeConfiguration) -> ();
  signIn: (email: text, passwordHash: text) -> (AuthResult);
  signOut: (token: text) -> ();
  signUp: (email: text, passwordHash: text) -> (AuthResult);
  transform: (input: TransformationInput) -> (TransformationOutput) query;
  updatePrint: (printId: PrintId, updates: PrintUpdate) -> ();
  updateProduct: (product: Product) -> ();
  validateSession: (token: text) -> (AuthResult);
}
